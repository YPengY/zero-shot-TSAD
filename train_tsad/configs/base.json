{
  "experiment_name": "timercd-base",
  "data": {
    "dataset_root": "datasets/synthetic_rcd/v1",
    "split": "train",
    "validation_split": "val",
    "test_split": "test",
    "use_sharded_dataset": true,
    "manifest_name_template": "manifest.{split}.jsonl",
    "context_size": 1024,
    "patch_size": 16,
    "stride": 512,
    "batch_size": 64,
    "eval_batch_size": 64,
    "num_workers": 0,
    "shuffle": true,
    "pin_memory": true,
    "include_tail": true,
    "pad_short_sequences": true,
    "drop_last": false,
    "enable_patch_masking": true,
    "mask_ratio": 0.2
  },
  "model": {
    "name": "timercd",
    "patch_size": 16,
    "d_model": 512,
    "d_proj": 256,
    "num_layers": 8,
    "num_heads": 8,
    "mlp_ratio": 4.0,
    "dropout": 0.1,
    "attention_dropout": 0.1,
    "activation": "gelu",
    "use_learned_positional_encoding": true
  },
  "loss": {
    "anomaly_loss_weight": 1.0,
    "reconstruction_loss_weight": 0.2,
    "anomaly_pos_weight": null,
    "label_smoothing": 0.0
  },
  "optimizer": {
    "name": "adamw",
    "lr": 0.0005,
    "weight_decay": 0.00001,
    "betas": [0.9, 0.999],
    "eps": 0.00000001,
    "scheduler": "cosine",
    "warmup_epochs": 0,
    "min_lr": 0.0
  },
  "train": {
    "output_dir": "runs/timercd_base",
    "seed": 42,
    "device": "cuda",
    "max_epochs": 50,
    "early_stopping_patience": 7,
    "gradient_clip_norm": 1.0,
    "gradient_accumulation_steps": 1,
    "log_every_n_steps": 50,
    "validate_every_n_epochs": 1,
    "save_best_only": false,
    "mixed_precision": false
  },
  "eval": {
    "threshold": 0.5,
    "threshold_search": false,
    "threshold_search_metric": "f1",
    "score_reduction": "mean",
    "point_score_aggregation": "mean"
  },
  "tags": ["synthetic", "timercd", "paper-aligned"]
}
