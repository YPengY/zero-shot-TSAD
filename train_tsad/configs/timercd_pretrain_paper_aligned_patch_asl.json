{
  "experiment_name": "timercd-pretrain-paper-aligned-patch-asl",
  "data": {
    "dataset_root": "datasets/synthetic_rcd/v1",
    "split": "train",
    "validation_split": "val",
    "test_split": "test",
    "use_sharded_dataset": true,
    "manifest_name_template": "manifest.{split}.jsonl",
    "context_size": 1024,
    "patch_size": 16,
    "stride": 1024,
    "batch_size": 64,
    "eval_batch_size": 64,
    "num_workers": 0,
    "max_cached_shards": 128,
    "shuffle": true,
    "shuffle_strategy": "shard_block",
    "pin_memory": true,
    "include_tail": true,
    "pad_short_sequences": true,
    "drop_last": false,
    "enable_patch_masking": true,
    "mask_ratio": 0.2,
    "load_normal_series": false,
    "load_metadata": false,
    "enable_direct_window_read": true,
    "normalization_mode": "per_sample_per_feature_zscore",
    "normalization_eps": 1e-05
  },
  "model": {
    "name": "timercd",
    "patch_size": 16,
    "d_model": 512,
    "d_proj": 256,
    "num_layers": 8,
    "num_heads": 8,
    "mlp_ratio": 4.0,
    "dropout": 0.1,
    "attention_dropout": 0.1,
    "activation": "gelu",
    "use_learned_positional_encoding": true,
    "use_shared_output_projection": true,
    "use_observation_space_anomaly_head": true,
    "anomaly_patch_aggregation": "or"
  },
  "loss": {
    "anomaly_loss_weight": 1.0,
    "point_anomaly_loss_weight": 0.5,
    "reconstruction_loss_weight": 1.0,
    "anomaly_loss_type": "asl",
    "anomaly_pos_weight": null,
    "anomaly_asl_gamma_neg": 2.0,
    "anomaly_asl_gamma_pos": 0.0,
    "anomaly_asl_clip": 0.05,
    "point_anomaly_pos_weight": "auto",
    "label_smoothing": 0.0
  },
  "optimizer": {
    "name": "adamw",
    "lr": 0.0005,
    "weight_decay": 0.00001,
    "betas": [
      0.9,
      0.999
    ],
    "eps": 0.00000001,
    "scheduler": "cosine",
    "warmup_epochs": 0,
    "min_lr": 0.0
  },
  "train": {
    "output_dir": "runs/timercd_pretrain_paper_aligned_patch_asl",
    "seed": 42,
    "device": "cuda",
    "max_epochs": 50,
    "early_stopping_patience": 7,
    "gradient_clip_norm": 1.0,
    "gradient_accumulation_steps": 1,
    "log_every_n_steps": 50,
    "validate_every_n_epochs": 1,
    "save_best_only": false,
    "mixed_precision": true,
    "progress_write_interval_seconds": 2.0
  },
  "eval": {
    "task": "patch_feature",
    "primary_metric": "pr_auc",
    "primary_metric_mode": "max",
    "threshold": 0.5,
    "threshold_search": true,
    "threshold_search_metric": "f1",
    "patch_feature_score_aggregation": "mean",
    "report_per_feature": false,
    "report_per_sample": false,
    "score_reduction": "mean",
    "point_score_aggregation": "mean"
  },
  "tags": [
    "synthetic",
    "timercd",
    "paper-aligned",
    "pretraining",
    "patch-asl"
  ]
}
