{
    "experiment_name":  "timercd-small",
    "data":  {
                 "dataset_root":  "datasets/synthetic_rcd/v1",
                 "split":  "train",
                 "validation_split":  "val",
                 "test_split":  "test",
                 "use_sharded_dataset":  true,
                 "manifest_name_template":  "manifest.{split}.jsonl",
                 "context_size":  512,
                 "patch_size":  16,
                 "stride":  512,
                 "batch_size":  16,
                 "eval_batch_size":  16,
                 "num_workers":  0,
                 "shuffle":  true,
                 "pin_memory":  true,
                 "include_tail":  false,
                 "pad_short_sequences":  false,
                 "drop_last":  false,
                 "enable_patch_masking":  true,
                 "mask_ratio":  0.2,
                 "enable_direct_window_read":  true
             },
    "model":  {
                  "name":  "timercd",
                  "patch_size":  16,
                  "d_model":  256,
                  "d_proj":  128,
                  "num_layers":  4,
                  "num_heads":  4,
                  "mlp_ratio":  4.0,
                  "dropout":  0.1,
                  "attention_dropout":  0.1,
                  "activation":  "gelu",
                  "use_learned_positional_encoding":  true
              },
    "loss":  {
                 "anomaly_loss_weight":  1.0,
                 "reconstruction_loss_weight":  0.01,
                 "anomaly_pos_weight":  "auto",
                 "label_smoothing":  0.0
             },
    "optimizer":  {
                      "name":  "adamw",
                      "lr":  0.0005,
                      "weight_decay":  0.00001,
                      "betas":  [
                                    0.9,
                                    0.999
                                ],
                      "eps":  0.00000001,
                      "scheduler":  "cosine",
                      "warmup_epochs":  0,
                      "min_lr":  0.0
                  },
    "train":  {
                  "output_dir":  "runs/timercd_small",
                  "seed":  42,
                  "device":  "cuda",
                  "max_epochs":  20,
                  "early_stopping_patience":  5,
                  "gradient_clip_norm":  1.0,
                  "gradient_accumulation_steps":  1,
                  "log_every_n_steps":  25,
                  "validate_every_n_epochs":  1,
                  "save_best_only":  false,
                  "mixed_precision":  false
              },
    "eval":  {
                 "task":  "patch_feature",
                 "primary_metric":  "pr_auc",
                 "primary_metric_mode":  "max",
                 "threshold":  0.5,
                 "threshold_search":  true,
                 "threshold_search_metric":  "f1",
                 "patch_feature_score_aggregation":  "mean",
                 "report_per_feature":  false,
                 "report_per_sample":  false,
                 "score_reduction":  "mean",
                 "point_score_aggregation":  "mean"
             },
    "tags":  [
                 "synthetic",
                 "timercd",
                 "smoke-test"
             ]
}
